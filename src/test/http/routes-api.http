### Cultural Navigator Routes API checks
### Base URL
@host = http://localhost:8080/cultural

### 1) Open login page and capture login CSRF token
# @name loginPage
GET {{host}}/login

> {%
    const token = response.body.match(/name="_csrf" value="([^"]+)"/)?.[1];
    client.assert(token, "CSRF token was not found on login page");
    client.global.set("login_csrf_token", token);
%}

### 2) Login. IntelliJ HTTP Client stores JSESSIONID automatically in its cookie jar.
# @name login
POST {{host}}/login
Content-Type: application/x-www-form-urlencoded

username=admin&password=admin&_csrf={{login_csrf_token}}

### 3) Open protected form and capture current API CSRF token
# @name routeForm
GET {{host}}/routes/new

> {%
    const token = response.body.match(/name="_csrf" value="([^"]+)"/)?.[1]
        || response.body.match(/name="_csrf" content="([^"]+)"/)?.[1];
    client.assert(token, "CSRF token was not found on route form");
    client.global.set("csrf_token", token);
%}

### 4) Create route
# @name createRoute
POST {{host}}/api/routes
Content-Type: application/json
X-XSRF-TOKEN: {{csrf_token}}

{
  "title": "Маршрут выходного дня",
  "description": "Два культурных события на спокойный вечер",
  "durationMinutes": 120,
  "budget": 500,
  "isPublic": true,
  "eventIds": [1],
  "authorId": 0
}
> {%
    client.test("Route was created", function() {
        client.assert(response.status === 201, "Expected 201 Created, got " + response.status);
        client.assert(response.body.id, "Response body does not contain route id");
    });
    client.global.set("route_id", response.body.id);
%}

### 5) Read all routes
GET {{host}}/api/routes

### 6) Read route by id
GET {{host}}/api/routes/{{route_id}}

### 7) Update route
PUT {{host}}/api/routes/{{route_id}}
Content-Type: application/json
X-XSRF-TOKEN: {{csrf_token}}

{
  "title": "Обновлённый маршрут на вечер",
  "description": "Обновлённое описание маршрута",
  "durationMinutes": 150,
  "budget": 750,
  "isPublic": true,
  "eventIds": [1],
  "authorId": 0
}

### 8) Delete route
DELETE {{host}}/api/routes/{{route_id}}
X-XSRF-TOKEN: {{csrf_token}}

### 9) Verify 404 after delete
GET {{host}}/api/routes/{{route_id}}
