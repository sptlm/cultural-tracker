### Cultural Navigator Routes API checks
### Base URL
@host = http://localhost:8080

### 1) Obtain session cookie (Spring Security form login)
# @name login
POST {{host}}/login
Content-Type: application/x-www-form-urlencoded

username=admin&password=admin
> {%
    const cookies = response.headers.valuesOf("Set-Cookie");
    const sessionCookie = cookies.find(cookie => cookie.startsWith("JSESSIONID")) || cookies[0];
    client.global.set("session_cookie", sessionCookie);
%}

### 2) Create route
# @name createRoute
POST {{host}}/api/routes
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "title": "Маршрут выходного дня",
  "authorId": 0
}
> {%
    client.test("Route was created", function() {
        client.assert(response.status === 201, "Expected 201 Created, got " + response.status);
        client.assert(response.body.id, "Response body does not contain route id");
    });
    client.global.set("route_id", response.body.id);
%}

### 3) Read all routes
GET {{host}}/api/routes
Cookie: {{session_cookie}}

### 4) Read route by id
GET {{host}}/api/routes/{{route_id}}
Cookie: {{session_cookie}}

### 5) Update route
PUT {{host}}/api/routes/{{route_id}}
Content-Type: application/json
Cookie: {{session_cookie}}

{
  "title": "Обновлённый маршрут на вечер",
  "authorId": 0
}

### 6) Delete route
DELETE {{host}}/api/routes/{{route_id}}
Cookie: {{session_cookie}}

### 7) Verify 404 after delete
GET {{host}}/api/routes/{{route_id}}
Cookie: {{session_cookie}}
